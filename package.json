{
  "name": "notebook-app",
  "private": true,
  "version": "1.4.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "package": "npm run audit && npm run build && node scripts/package.mjs",
    "prepare:git-pack": "node scripts/prepare-git-pack.mjs",
    "audit": "npm audit --audit-level=moderate",
    "deploy:staging": "node scripts/deploy-staging.mjs",
    "e2e:package-and-deploy": "npm run package && npm run deploy:staging",
    "e2e": "npm run e2e:quick && npm run e2e:slow",
    "e2e:quick": "playwright test --config=e2e/playwright.config.ts --project=chromium-staging --grep-invert '@slow|@examples-all'",
    "e2e:examples": "playwright test --config=e2e/playwright.config.ts --project=chromium-staging --grep '@examples-all' --grep-invert '@heavy' --workers=1",
    "e2e:examples:all": "playwright test --config=e2e/playwright.config.ts --project=chromium-staging --grep '@examples-all' --workers=1",
    "e2e:examples:from-cribl-search": "playwright test --config=e2e/playwright.config.ts --project=chromium-staging --grep '(Cribl Search Examples|AI Magic|Cribl API Examples|Visualisations|Cribl Search Lookup Magics):' --workers=1",
    "e2e:slow": "playwright test --config=e2e/playwright.config.ts --project=chromium-staging --grep '@slow' --grep-invert '@heavy' --workers=1",
    "e2e:slow:all": "playwright test --config=e2e/playwright.config.ts --project=chromium-staging --grep '@slow' --workers=1",
    "e2e:auth": "playwright test --config=e2e/playwright.setup.config.ts --project=setup",
    "e2e:install": "playwright install chromium",
    "e2e:report": "playwright show-report",
    "update:cribl-api": "node scripts/cribl-openapi-to-catalog.mjs",
    "update:cribl-api:release": "CRIBL_OPENAPI_CHANNEL=release node scripts/cribl-openapi-to-catalog.mjs",
    "release:github-notes": "node --experimental-strip-types scripts/emit-github-release-notes.ts"
  },
  "dependencies": {
    "@codemirror/autocomplete": "6.20.1",
    "@codemirror/commands": "6.10.3",
    "@codemirror/lang-python": "6.2.1",
    "@codemirror/language": "6.12.3",
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.41.0",
    "@jupyter-widgets/base": "6.0.11",
    "@jupyter-widgets/base-manager": "1.0.12",
    "@jupyter-widgets/controls": "5.0.12",
    "@lezer/highlight": "1.2.3",
    "dompurify": "3.4.11",
    "marked": "18.0.5",
    "plotly.js": "3.5.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-plotly.js": "2.6.0",
    "react-router-dom": "7.18.1",
    "vega": "6.2.0",
    "vega-embed": "7.1.0",
    "vega-lite": "6.4.3",
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.59.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/dompurify": "3.0.5",
    "@types/node": "24.12.2",
    "@types/plotly.js": "3.0.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-plotly.js": "2.6.4",
    "@vitejs/plugin-react": "6.0.1",
    "dotenv": "16.6.1",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.1.0",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.5.0",
    "jsdom": "29.0.2",
    "pyodide": "0.29.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "vite": "8.1.3",
    "vitest": "4.1.4"
  },
  "displayName": "Jupyter notebook app",
  "description": "An application that can run a Jupyter notebook app in the browser",
  "author": "Michael Hyatt",
  "license": "BSD-3-Clause"
}
