{
  "name": "notebook-app",
  "private": true,
  "version": "1.0.15",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "vendor-pyodide": "node scripts/vendor-pyodide-wheels.mjs",
    "build": "tsc -b && npm run vendor-pyodide && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "package": "npm run build && node scripts/package.mjs"
  },
  "dependencies": {
    "dompurify": "^3.4.0",
    "marked": "^18.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "pyodide": "^0.29.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  },
  "displayName": "Jupyter notebook app",
  "description": "An application that can run a Jupyter notebook app in the browser",
  "author": "Michael Hyatt"
}
