{
  "name": "notebook-app",
  "private": true,
  "version": "1.0.70",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "package": "npm run build && node scripts/package.mjs",
    "deploy:staging": "node scripts/deploy-staging.mjs",
    "e2e:package-and-deploy": "npm run package && npm run deploy:staging",
    "e2e": "playwright test --config=e2e/playwright.config.ts --project=chromium-staging",
    "e2e:quick": "playwright test --config=e2e/playwright.config.ts --project=chromium-staging --grep-invert '@slow'",
    "e2e:auth": "playwright test --config=e2e/playwright.setup.config.ts --project=setup",
    "e2e:install": "playwright install chromium",
    "e2e:report": "playwright show-report",
    "update:cribl-api": "node scripts/cribl-openapi-to-catalog.mjs",
    "update:cribl-api:release": "CRIBL_OPENAPI_CHANNEL=release node scripts/cribl-openapi-to-catalog.mjs"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.1",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.11.3",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.11",
    "@lezer/highlight": "^1.2.3",
    "dompurify": "^3.4.0",
    "marked": "^18.0.1",
    "plotly.js": "^3.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-plotly.js": "^2.6.0",
    "react-router-dom": "^7.14.1",
    "vega": "^5.33.1",
    "vega-embed": "^6.29.0",
    "vega-lite": "^5.23.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.12.2",
    "@types/plotly.js": "^3.0.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-plotly.js": "^2.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "pyodide": "^0.29.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  },
  "displayName": "Jupyter notebook app",
  "description": "An application that can run a Jupyter notebook app in the browser",
  "author": "Michael Hyatt"
}
