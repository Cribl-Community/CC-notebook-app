# Copy to e2e/.env (gitignored). Never commit real URLs with embedded tokens.

# Staging tenant origin (no trailing slash), e.g. https://your-org.cribl-staging.cloud
CRIBL_E2E_BASE_URL=https://appplat-recursing-chaplygin-4o26sjd.cribl-staging.cloud

# Page to open after login — Apps gallery or deep link to the mounted notebook app
CRIBL_E2E_START_PATH=/apps

# Full URL override (optional). When set, overrides BASE_URL + START_PATH.
# CRIBL_E2E_START_URL=

# Saved auth from `npm run e2e:auth` (gitignored)
CRIBL_E2E_STORAGE_STATE=e2e/.auth/storageState.json

# --- Deploy script (scripts/deploy-staging.mjs) — CI secrets only ---
# CRIBL_DEPLOY_URL=
# CRIBL_API_TOKEN=
