# Copy to e2e/.env (gitignored). Never commit real URLs with embedded tokens.

# Staging tenant origin (no trailing slash), e.g. https://your-org.cribl-staging.cloud
CRIBL_E2E_BASE_URL=https://appplat-recursing-chaplygin-4o26sjd.cribl-staging.cloud

# Page to open after login — `/apps` is OK: tests click the notebook pack row automatically.
CRIBL_E2E_START_PATH=/apps

# Optional: open this pack directly (skips catalog click). Bump version when the pack id changes.
# CRIBL_E2E_APP_PACK_PATH=/apps/a/notebook-app-1-0-68-tgz

# Optional: href substring for the catalog link (default notebook-app)
# CRIBL_E2E_APP_PACK_SUBSTRING=notebook-app

# Full URL override (optional). When set, overrides BASE_URL + START_PATH.
# CRIBL_E2E_START_URL=

# Saved auth from `npm run e2e:auth` (gitignored)
CRIBL_E2E_STORAGE_STATE=e2e/.auth/storageState.json

# Optional: CSS on the parent page that appears only after login (for unattended auth capture)
# CRIBL_E2E_POST_LOGIN_SELECTOR=

# Performance budget (ms) for time-to-visible shell (catalog click + Pyodide can be slow)
# CRIBL_E2E_PERF_SHELL_MS=180000

# --- Deploy script (scripts/deploy-staging.mjs) — CI secrets only ---
# CRIBL_DEPLOY_URL=
# CRIBL_API_TOKEN=
